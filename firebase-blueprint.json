{
  "entities": {
    "User": {
      "title": "User",
      "description": "Authenticated user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "description": "URL to user's profile picture" },
        "likes": { "type": "array", "items": { "type": "string" }, "description": "List of movie IDs liked by the user" },
        "saved": { "type": "array", "items": { "type": "string" }, "description": "List of movie IDs saved by the user" },
        "followingActors": { "type": "array", "items": { "type": "string" }, "description": "List of actor IDs followed by the user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the user was created" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    }
  }
}
